# ─── Database (Neon / any PostgreSQL) ────────────────────────────────────────
# Get from https://neon.tech → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# For Prisma migrations (non-pooled URL on Neon — omit ?pgbouncer=true)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── AI (Groq) ────────────────────────────────────────────────────────────────
# Get from https://console.groq.com
GROQ_API_KEY="gsk_..."

# Model to use — llama-3.3-70b-versatile is the sweet spot
GROQ_MODEL="llama-3.3-70b-versatile"

# ─── Agent tools — real data sources (the agent will tell users what's missing) ─
# SerpApi powers flight search, hotel search, Google Maps, and web search.
# Get a free-tier key at https://serpapi.com
SERP_API_KEY=""

# Weatherstack — live weather lookups. Free tier at https://weatherstack.com
WEATHER_API_KEY=""

# ExchangeRate-API — live currency conversion. Free tier at https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=""

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="your-nextauth-secret"

# The public URL of your deployment (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional — remove if not using) ───────────────────────────
# Console: https://console.cloud.google.com → APIs → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Cloudinary (optional — for cover photo uploads) ─────────────────────────
# Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Guest plan limit ─────────────────────────────────────────────────────────
# How many free AI plan runs a non-logged-in visitor gets before sign-in gate
GUEST_FREE_RUNS=3
